#: src/migration.md:13
msgid "Remove `[tool.maturin.sdist-include]`"
msgstr ""

#: src/migration.md:15
msgid "Use `[tool.maturin.include]` option instead."
msgstr ""

#: src/migration.md:17
msgid "Remove `[package.metadata.maturin]` from `Cargo.toml`"
msgstr ""

#: src/migration.md:19
msgid ""
"Package metadata is now specified in `[tool.maturin]` section of `pyproject."
"toml` instead of `Cargo.toml`. Note that the replacement for `package."
"metadata.maturin.name` is `tool.maturin.module-name`."
msgstr ""

#: src/migration.md:22
msgid "Require `uniffi-bindgen` CLI to building `uniffi` bindings"
msgstr ""

#: src/migration.md:24
msgid ""
"maturin 0.15 requires `uniffi-bindgen` CLI to build `uniffi` bindings, you "
"can install it with `pip install uniffi-bindgen`."
